# Dependencies
foundry-app/node_modules/

# NOTE: foundry-app/dist/ is intentionally tracked. GitHub Pages serves
# the pre-built bundle from dist/, so it must be committed for deploys
# to reflect source changes. Run `npm run build` before committing.

# Native platforms (built locally, not needed in repo)
foundry-app/android/
foundry-app/ios/

# Environment files
foundry-app/.env

# IDE
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Large image files at root
*.png
# Allow all shipped public assets (PWA icons + onboarding imagery, etc.)
!foundry-app/public/*.png
# Allow built dist PNGs (Vite copies public/ into dist/ on build)
!foundry-app/dist/*.png

# Old anchor icon option files
anchor_icon_options*.html
