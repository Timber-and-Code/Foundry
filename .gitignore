# Dependencies
foundry-app/node_modules/

# Build output — GitHub Actions builds and deploys via actions/deploy-pages
foundry-app/dist/

# Native platforms (built locally, not needed in repo)
foundry-app/android/
foundry-app/ios/

# Environment files
foundry-app/.env

# IDE
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Large image files at root
*.png
# Allow all shipped public assets (PWA icons + onboarding imagery, etc.)
!foundry-app/public/*.png

# Old anchor icon option files
anchor_icon_options*.html
